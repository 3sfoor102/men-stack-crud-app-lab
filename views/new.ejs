<%- include('./partials/nav') %>

<h1>Book Your Photography Session</h1>

<form action="/photography" method="POST">
<label>Name:</label> 
<input type="text" name="name" required/>
<br/>
<label>Email:</label>
<input type="email" name="email" required/>
<br/>
<label>Phone</label>
<input type="number" name="phone" required/>
<br/>
<label>Date</label> 
<input type="date" name="reservationDate" required/>
<br/>
<label>Package: </label>
<select name="reservationPackage">
    <option value="Weeding-photography">Wedding Photography Only </option>
    <option value="Weeding-photography-videography">Wedding Photography & Videography </option>

</select>
<br/>

<button class="submit" type="submit">Book</button>
</form>
</body>
</html>